# Copiar este archivo como .env.local (desarrollo) o .env.prod (producción)
# y ajustar los valores según el entorno.

# --- Desarrollo local ---
# DATABASE_URL=postgresql://notionlocal:dark@localhost:5432/notionlocal

# --- Producción (Docker Compose) ---
# Las variables POSTGRES_* las usa docker-compose.prod.yml
# DATABASE_URL se construye automáticamente desde ellas.

POSTGRES_USER=notionlocal
POSTGRES_PASSWORD=cambiar_por_contraseña_segura
POSTGRES_DB=notionlocal
